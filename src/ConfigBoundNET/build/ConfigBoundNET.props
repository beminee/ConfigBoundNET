<Project>

  <!--
    Default properties for ConfigBoundNET schema emission.
    Imported by NuGet automatically because this file matches the package
    id and lives under build/ in the .nupkg.

    Consumers opt in to file emission by setting:
        <ConfigBoundEmitSchema>true</ConfigBoundEmitSchema>
    in their csproj. The default (empty / false) keeps v2.x behaviour:
    the schema const is still generated by the source generator and
    reachable as ConfigBoundNET.ConfigBoundJsonSchema.Json at runtime, but
    no file is written to disk.
  -->

  <PropertyGroup>
    <!-- Default opt-in flag. Users override in their csproj. Empty is
         treated the same as "false" by the Condition on the target. -->
    <ConfigBoundEmitSchema Condition="'$(ConfigBoundEmitSchema)' == ''">false</ConfigBoundEmitSchema>

    <!-- Default schema output path. The file lives in the project
         directory so "$schema": "./appsettings.schema.json" in a
         checked-in appsettings.json resolves correctly. Users can override
         to any path, relative or absolute. -->
    <ConfigBoundSchemaOutputPath Condition="'$(ConfigBoundSchemaOutputPath)' == ''">$(MSBuildProjectDirectory)\appsettings.schema.json</ConfigBoundSchemaOutputPath>
  </PropertyGroup>

</Project>
